# Hugging Face Token
# Required for accessing gated models (e.g., Gemma, Llama)
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# OpenAI API Key
# Required for using OpenAI ChatGPT models (gpt-4, gpt-3.5-turbo, etc.)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Gemini cookies (from DevTools → Application → Cookies → https://gemini.google.com)
GEMINI_SECURE_1PSID=
GEMINI_SECURE_1PSIDTS=